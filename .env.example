# Use "db" as host when running in devcontainer/docker, "localhost" when running natively
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wp_updater?schema=public"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-random-secret"

# Optional: enable GitHub OAuth login for admin dashboard
GITHUB_AUTH_CLIENT_ID=""
GITHUB_AUTH_CLIENT_SECRET=""
GITHUB_AUTH_ALLOWED_ORG=""
NEXT_PUBLIC_GITHUB_AUTH_ENABLED="false"

# Optional: enable Google OAuth login for admin dashboard
# Create credentials at https://console.cloud.google.com/apis/credentials
# Callback URL: https://your-domain.com/api/auth/callback/google
GOOGLE_AUTH_CLIENT_ID=""
GOOGLE_AUTH_CLIENT_SECRET=""
# Optional: restrict to a Google Workspace domain (e.g. "yourcompany.com")
GOOGLE_AUTH_ALLOWED_DOMAIN=""

GITHUB_APP_ID=""
GITHUB_APP_PRIVATE_KEY=""
GITHUB_APP_INSTALLATION_ID=""

# Initial admin credentials (used by seed script)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="changeme"
