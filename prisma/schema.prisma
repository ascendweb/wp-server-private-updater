generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String?
  name      String?
  role      String    @default("admin")
  status    String    @default("active")
  createdAt DateTime  @default(now())
  accounts  Account[]
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String
  providerAccountId String
  createdAt         DateTime @default(now())

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Plugin {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String?
  githubOwner String
  githubRepo  String
  releaseAssetPattern String @default("{slug}-v{version}.zip")
  testedWp    String?   @default("6.7")
  requiresPhp String?  @default("8.0")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  licenses    License[]

  @@unique([githubOwner, githubRepo])
}

model License {
  id          String    @id @default(cuid())
  key         String    @unique @default(cuid())
  pluginId    String?
  plugin      Plugin?   @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  siteUrl     String
  label       String?
  status      String    @default("active")
  lastCheckAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([key, status])
  @@index([siteUrl])
}
