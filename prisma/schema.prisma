generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String?
  name      String?
  role      String    @default("admin")
  status    String    @default("active")
  createdAt DateTime  @default(now())
  accounts  Account[]
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String
  providerAccountId String
  createdAt         DateTime @default(now())

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Plugin {
  id                  String       @id @default(cuid())
  slug                String       @unique
  name                String
  description         String?
  githubOwner         String
  githubRepo          String
  releaseAssetPattern String       @default("{slug}-v{version}.zip")
  testedWp            String?      @default("6.7")
  requiresPhp         String?      @default("8.0")
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  sitePlugins         SitePlugin[]
  sitePluginVersions  SitePluginVersion[]

  @@unique([githubOwner, githubRepo])
}

model Site {
  id        String       @id @default(cuid())
  url       String       @unique
  label     String?
  siteToken String?
  pushUrl   String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  licenses            License[]
  plugins             SitePlugin[]
  commands            Command[]
  sitePluginVersions  SitePluginVersion[]
}

model License {
  id          String    @id @default(cuid())
  key         String    @unique @default(cuid())
  siteId      String?
  site        Site?     @relation(fields: [siteId], references: [id], onDelete: SetNull)
  siteUrl     String
  label       String?
  status      String    @default("active")
  lastCheckAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([key, status])
  @@index([siteUrl])
  @@index([siteId])
}

model SitePlugin {
  id               String    @id @default(cuid())
  siteId           String
  site             Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  pluginSlug       String
  pluginId         String?
  plugin           Plugin?   @relation(fields: [pluginId], references: [id], onDelete: SetNull)
  pluginBasename   String?
  pluginName       String?
  installedVersion String?
  isActive         Boolean   @default(false)
  isLocked         Boolean   @default(false)
  lastReportedAt   DateTime  @default(now())

  @@unique([siteId, pluginSlug])
  @@index([pluginSlug])
  @@index([pluginId])
}

enum CommandType {
  update
  install
  rollback
}

enum CommandStatus {
  pending
  delivered
  in_progress
  completed
  failed
}

model Command {
  id            String        @id @default(cuid())
  siteId        String
  site          Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  type          CommandType
  pluginSlug    String
  targetVersion String?
  packageUrl    String?
  status        CommandStatus @default(pending)
  result        String?
  createdAt     DateTime      @default(now())
  deliveredAt   DateTime?
  completedAt   DateTime?

  @@index([siteId, status])
  @@index([status])
}

model SitePluginVersion {
  id               String   @id @default(cuid())
  siteId           String
  site             Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  pluginId         String
  plugin           Plugin   @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  availableVersion String?
  autoSync         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([siteId, pluginId])
  @@index([pluginId])
  @@index([siteId])
}
